@model IEnumerable<Biblioteca_de_Jogos.Models.Jogo>
@{
    ViewData["Title"] = "Minha Biblioteca";
    var usuarioLogado = Context.Session.GetString("UsuarioNome");
    var isAdmin = Context.Session.GetString("IsAdmin") == "True";
    var totalPendentes = ViewBag.TotalPendentes as int? ?? 0;
    var totalRespostas = ViewBag.TotalRespostas as int? ?? 0;
    var totalMeusJogos = ViewBag.TotalMeusJogos as int? ?? 0;
    var totalComunidade = ViewBag.TotalComunidade as int? ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Biblioteca de Jogos</h2>
        <div class="d-flex gap-2 align-items-center">
            @if (isAdmin)
            {
                <span class="badge bg-danger">Admin</span>
            }
            <a asp-controller="Home" asp-action="EditarPerfil"
               class="btn btn-outline-secondary btn-sm position-relative"
               title="Editar perfil">
                👤 @usuarioLogado
            </a>

            <a asp-controller="Emprestimo" asp-action="Notificacoes"
                   class="btn btn-outline-secondary btn-sm position-relative"
            title="Notificações">
                ✉️
                @if (totalPendentes > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle
                        badge rounded-pill bg-danger">
                        @totalPendentes
                    </span>
                }
            </a>

            <a asp-action="Create" class="btn btn-primary btn-sm" title="Adicionar Jogo">+ Adicionar Jogo</a>
            <a asp-action="Logout" asp-controller="Home" class="btn btn-outline-secondary btn-sm" title="Sair">Sair</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="row g-2">
                <div class="col">
                    <input id="filtroNome" type="text" class="form-control"
                           placeholder="Buscar por nome..." oninput="filtrar()" />
                </div>
                <div class="col">
                    <select id="filtroConsole" class="form-select" onchange="filtrar()">
                        <option value="">Todos os consoles</option>
                        @foreach (var console in Model.Select(j => j.txt_Console).Distinct().OrderBy(c => c))
                        {
                            <option value="@console">@console</option>
                        }
                    </select>
                </div>
                <div class="col">
                    <select id="filtroUsuario" class="form-select" onchange="filtrar()">
                        <option value="">Todos os usuário</option>
                        @foreach (var usuario in Model.Select(u => u.txt_Dono).Distinct().OrderBy(g => g))
                        {
                            <option value="@usuario">@usuario</option>
                        }
                    </select>
                </div>
                <div class="col">
                    <select id="filtroGenero" class="form-select" onchange="filtrar()">
                        <option value="">Todos os gêneros</option>
                        @foreach (var genero in Model.Select(j => j.txt_Genero).Distinct().OrderBy(g => g))
                        {
                            <option value="@genero">@genero</option>
                        }
                    </select>
                </div>
                <div class="col">
                    <select id="filtroDisponivel" class="form-select" onchange="filtrar()">
                        <option value=""> Todos</option>
                        <option value="disponivel">Disponíveis</option>
                        <option value="emprestado">Emprestados</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="abas">
        <li class="nav-item">
            <button class="nav-link active" style="color: black" id="btn-meus" onclick="trocarAba('meus')"> Meus Jogos (@totalMeusJogos)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" style="color: black" id="btn-comunidade" onclick="trocarAba('comunidade')"> Comunidade (@totalComunidade)</button>
        </li>
        @* <li class="nav-item">
            <button class="nav-link" style="color: black" id="btn-perifericos" onclick="trocarAba('prefireficos')"> Perifericos</button>
        </li> *@
    </ul>

    <div id="semResultados" class="alert alert-info d-none">
        Nenhum jogo encontrado com os filtros selecionados.
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4" id="listaJogos">
        @foreach (var jogo in Model)
        {
            var temPermissao = isAdmin || jogo.txt_Dono == usuarioLogado;
            var ehDono = jogo.txt_Dono == usuarioLogado;
            var aba = ehDono ? "meus" : "comunidade";

            <div class="col jogo-card"
                 data-aba="@aba"
                 data-nome="@jogo.txt_Nome.ToLower()"
                 data-console="@jogo.txt_Console"
                 data-genero="@jogo.txt_Genero"
                 data-usuario="@jogo.txt_Dono"
                 data-disponivel="@(jogo.bool_EstaEmprestado ? "emprestado" : "disponivel")">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(jogo.txt_FotoUrl))
                    {
                        <img src="@jogo.txt_FotoUrl" class="card-img-top"
                             style="height:180px; object-fit:cover;" alt="@jogo.txt_Nome" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@jogo.txt_Nome</h5>
                        <p class="card-text text-muted mb-1">🎯 @jogo.txt_Genero</p>
                        <p class="card-text text-muted mb-1">🎮 @jogo.txt_Console</p>
                        <p class="card-text text-muted mb-1">⏱️ @jogo.int_HorasParaZerar horas para zerar</p>
                        <p class="card-text mb-1">👤 Dono: <strong>@jogo.txt_Dono</strong></p>

                        @if (jogo.bool_EstaEmprestado)
                        {
                            <span class="badge bg-warning text-dark">
                                📤 Emprestado para: @jogo.str_EmprestadoPara
                            </span>
                        }
                        else if(!jogo.bool_Disponivel)
                        {
                            <span class="badge bg-secondary">🔒 Indisponível</span>
                        }
                        else
                        {
                            <span class="badge bg-success">✅ Disponível</span>
                        }
                        @{ 
                            var solicitacoes = ViewBag.Solicitacoes as List<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>
                                               ?? new List<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>();
                            var solicitacoesDoJogo = solicitacoes.Where(s => s.int_JogoId == jogo.int_Id).ToList();
                        }
                        @if (solicitacoesDoJogo.Any())
                        {
                            <div class="mt-2">
                                @foreach (var s in solicitacoesDoJogo)
                                {
                                    <div class="alert alert-warning py-1 px-2 mb-1 small">
                                        <strong>@s.str_SolicitanteNome</strong> solicitou empréstimo
                                    </div>
                                }
                            </div>
                        }

                        @{
                            var avaliacoes = ViewBag.Avaliacoes as List<Biblioteca_de_Jogos.Models.Avaliacao>
                                             ?? new List<Biblioteca_de_Jogos.Models.Avaliacao>();
                            var avaliacoesDoJogo = avaliacoes.Where(a => a.int_JogoId == jogo.int_Id).ToList();
                            var media = avaliacoesDoJogo.Any() ? avaliacoesDoJogo.Average(a => a.int_Estrelas) : 0;
                        }
                        <p class="mb-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span style="color: @(i <= Math.Round(media) ? "#ffc107" : "#ccc"); font-size:1.1rem;">★</span>
                            }
                            <small class="text-muted">(@avaliacoesDoJogo.Count avaliações)</small>
                        </p>

                        <button class="btn btn-sm btn-outline-warning mt-1"
                                data-bs-toggle="modal"
                                data-bs-target="#modalAvaliar"
                                onclick="abrirModal(@jogo.int_Id, '@jogo.txt_Nome')">
                            Avaliar
                        </button>
                    </div>
                    <div class="card-footer d-flex flex-wrap gap-2">
                        @if (temPermissao)
                        {
                            <a asp-action="Edit" asp-route-id="@jogo.int_Id"
                               class="btn btn-sm btn-outline-primary">Editar</a>

                            <form asp-action="Delete" asp-route-id="@jogo.int_Id" method="post"
                                  onsubmit="return confirm('Remover @jogo.txt_Nome?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                            </form>

                            @if (jogo.bool_EstaEmprestado && ehDono)
                            {
                                <form asp-controller="Emprestimo" asp-action="Devolver" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="jogoId" value="@jogo.int_Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Devolvido</button>
                                </form>
                            }
                        }
                        else if (!jogo.bool_EstaEmprestado && jogo.bool_Disponivel)
                        {
                            <form asp-controller="Emprestimo" asp-action="Solicitar" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="jogoId" value="@jogo.int_Id" />
                                <button type="submit" class="btn btn-sm btn-outline-info">Pedir Emprestado</button>
                            </form>
                        }
                        else if (jogo.bool_EstaEmprestado)
                        {
                            <span class="text-muted small align-self-center">Emprestado</span>
                        }
                        else
                        {
                            <span class="text-muted small align-self-center">🔒 Indisponível</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="modalAvaliar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Avaliar: <span id="modalJogoNome"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-controller="Jogos" asp-action="Avaliar">
                @Html.AntiForgeryToken()
                <input type="hidden" name="jogoId" id="modalJogoId" />
                <div class="modal-body">
                    <div class="mb-3 text-center" id="estrelasContainer">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="estrela" data-valor="@i"
                                  style="font-size:2rem; cursor:pointer; color:#ccc;">★</span>
                        }
                        <input type="hidden" name="estrelas" id="estrelasValor" value="0" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning">Enviar Avaliação</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let abaAtual = 'meus';

        function trocarAba(aba) {
            abaAtual = aba;
            document.getElementById('btn-meus').classList.toggle('active', aba === 'meus');
            document.getElementById('btn-comunidade').classList.toggle('active', aba === 'comunidade');
            filtrar();
        }

        function filtrar() {
            const nome       = document.getElementById('filtroNome').value.toLowerCase();
            const console    = document.getElementById('filtroConsole').value;
            const genero     = document.getElementById('filtroGenero').value;
            const disponivel = document.getElementById('filtroDisponivel').value;
            const usuario = document.getElementById('filtroUsuario').value;

            const cards = document.querySelectorAll('.jogo-card');
            let visiveis = 0;

            cards.forEach(card => {
                const abaMatch        = card.dataset.aba === abaAtual;
                const nomeMatch       = card.dataset.nome.includes(nome);
                const consoleMatch    = !console    || card.dataset.console    === console;
                const generoMatch     = !genero     || card.dataset.genero     === genero;
                const disponivelMatch = !disponivel || card.dataset.disponivel === disponivel;
                const usuarioMatch    = !usuario    || card.dataset.usuario    === usuario;

                const visivel = abaMatch && nomeMatch && consoleMatch && generoMatch && disponivelMatch && usuarioMatch;
                card.style.display = visivel ? '' : 'none';
                if (visivel) visiveis++;
            });

            document.getElementById('semResultados').classList.toggle('d-none', visiveis > 0);
        }

        filtrar();

        function abrirModal(id, nome) {
            document.getElementById('modalJogoId').value = id;
            document.getElementById('modalJogoNome').textContent = nome;
            document.getElementById('estrelasValor').value = 0;
            document.querySelectorAll('.estrela').forEach(e => e.style.color = '#ccc');
        }

        document.querySelectorAll('.estrela').forEach(estrela => {
            estrela.addEventListener('click', function () {
                const val = parseInt(this.dataset.valor);
                document.getElementById('estrelasValor').value = val;
                document.querySelectorAll('.estrela').forEach(e => {
                    e.style.color = parseInt(e.dataset.valor) <= val ? '#ffc107' : '#ccc';
                });
            });
            estrela.addEventListener('mouseover', function () {
                const val = parseInt(this.dataset.valor);
                document.querySelectorAll('.estrela').forEach(e => {
                    e.style.color = parseInt(e.dataset.valor) <= val ? '#ffc107' : '#ccc';
                });
            });
        });
    </script>
}