@model Biblioteca_de_Jogos.Models.EditarPerfilViewModel
@{
    ViewData["Title"] = "Editar Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .perfil-container {
        max-width: 500px;
        margin: 50px auto;
        padding: 40px;
        background: rgba(255, 255, 255, 0.97);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

        .perfil-container h2 {
            color: #667eea;
            font-weight: 700;
        }

    .form-control {
        padding: 12px 15px;
        border-radius: 10px;
        border: 2px solid #e0e0e0;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

    .btn-salvar {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s ease;
    }

        .btn-salvar:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
            color: white;
        }

    .btn-excluir {
        width: 100%;
        padding: 12px;
        background: transparent;
        border: 2px solid #dc3545;
        border-radius: 10px;
        color: #dc3545;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s ease;
    }

        .btn-excluir:hover {
            background: #dc3545;
            color: white;
        }

    .divisor {
        border-top: 2px dashed #e0e0e0;
        margin: 30px 0;
    }
</style>

<div class="perfil-container">

    <div class="text-center mb-4">
        <div style="font-size: 3rem;">👤</div>
        <h2>Editar Perfil</h2>
        <p class="text-muted">Atualize suas informações</p>
    </div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger border-0 rounded-3">
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="EditarPerfil" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Nome" class="form-label fw-semibold">Nome de Usuário</label>
            <input asp-for="Nome" class="form-control" placeholder="Seu nome de usuário" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-semibold">E-mail</label>
            <input asp-for="Email" class="form-control" placeholder="Seu e-mail" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NovaSenha" class="form-label fw-semibold">Nova Senha</label>
            <input asp-for="NovaSenha" type="password" class="form-control"
                   placeholder="Deixe em branco para não alterar"
                   autocomplete="new-password" />
            <span asp-validation-for="NovaSenha" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmarSenha" class="form-label fw-semibold">Confirmar Nova Senha</label>
            <input asp-for="ConfirmarSenha" type="password" class="form-control"
                   placeholder="Repita a nova senha"
                   autocomplete="new-password" />
            <span asp-validation-for="ConfirmarSenha" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-salvar mb-3"> Salvar Alterações</button>

        <div class="text-center">
            <a asp-controller="Jogos" asp-action="Index"
                   class="text-decoration-underline text-secondary small">
                ← Voltar para a Biblioteca
            </a>
        </div>
    </form>

    <div class="divisor"></div>

    <div>
        <h6 class="text-danger fw-bold mb-1">Zona de Perigo</h6>
        <p class="text-muted small mb-3">
            Ao excluir sua conta, <strong>
            todos os seus jogos, solicitações e histórico
            serão removidos permanentemente
        </strong>. Esta ação não pode ser desfeita.
    </p>

    <button type="button" class="btn btn-excluir"
            data-bs-toggle="modal" data-bs-target="#modalExcluir">
         Excluir Minha Conta
    </button>
</div>
</div>

<div class="modal fade" id="modalExcluir" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirmar Exclusão</h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja excluir sua conta?</p>
                <ul class="text-danger small">
                    <li>Todos os seus jogos serão removidos</li>
                    <li>Todo o histórico de empréstimos será removido</li>
                    <li>Sua conta não poderá ser recuperada</li>
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form asp-action="ExcluirConta" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        Sim, excluir minha conta
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}